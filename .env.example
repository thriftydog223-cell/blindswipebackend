# ─── Database ───────────────────────────────────────────────────────────────
# Railway automatically sets DATABASE_URL when you add a Postgres service.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Auth ───────────────────────────────────────────────────────────────────
# A long, random secret used to sign JWT tokens.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret

# ─── Server ─────────────────────────────────────────────────────────────────
# Railway injects PORT automatically. You can leave this blank.
PORT=3000
NODE_ENV=production

# ─── Email (Nodemailer) ──────────────────────────────────────────────────────
# Used for forgot-password emails and email verification.
# Example using SendGrid SMTP:
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM=no-reply@wyndr.app

# ─── Push Notifications (Expo) ───────────────────────────────────────────────
# Optional — needed for push notifications to mobile clients.
EXPO_ACCESS_TOKEN=your_expo_access_token

# ─── File Uploads ────────────────────────────────────────────────────────────
# Photos are stored on disk under this path (configure a Railway volume, or
# swap multer's storage to S3/Cloudflare R2 for production).
UPLOAD_DIR=/app/uploads
