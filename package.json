{
  "name": "wyndr-api",
  "version": "1.0.0",
  "description": "Wyndr dating app — Express/Socket.io API server",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "dev": "NODE_ENV=development node ./build.mjs && node --enable-source-maps ./dist/index.mjs",
    "db:push": "drizzle-kit push --config ./drizzle.config.ts",
    "db:push-force": "drizzle-kit push --force --config ./drizzle.config.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@workspace/db": "file:./lib/db",
    "@workspace/api-zod": "file:./lib/api-zod",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "^0.43.1",
    "express": "^5",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pino": "^9",
    "pino-http": "^10",
    "socket.io": "^4.8.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pg": "^8.20.0",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "typescript": "^5.8.3"
  }
}
