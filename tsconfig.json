{
  "compilerOptions": {
    "isolatedModules": true, "lib": ["es2022"], "module": "esnext",
    "moduleResolution": "bundler", "noEmitOnError": true, "skipLibCheck": true,
    "target": "es2022", "types": ["node"], "outDir": "dist", "rootDir": "src",
    "strictNullChecks": true, "noImplicitAny": true, "alwaysStrict": true,
    "paths": {
      "@workspace/db": ["./lib/db/src/index.ts"],
      "@workspace/db/schema": ["./lib/db/src/schema/index.ts"],
      "@workspace/api-zod": ["./lib/api-zod/src/index.ts"]
    }
  },
  "include": ["src"]
}
